# ============================================================
# RAG System — 环境变量配置（示例）
# 使用方法：cp .env.example .env 然后填入真实值
# ============================================================

# --- LLM (DeepSeek) ---
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat

# --- 嵌入模型 (本地 bge-m3) ---
USE_LOCAL_EMBEDDING=True
LOCAL_EMBEDDING_PATH=./ml_models/bge-m3
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# --- HuggingFace 镜像 (国内加速) ---
HF_ENDPOINT=https://hf-mirror.com

# --- 重排序模型 (本地 bge-reranker-v2-m3) ---
RERANKER_MODEL_NAME=./ml_models/bge-reranker-v2-m3
